                  "pm.test('Approved driver login OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Driver token stored', function () { pm.expect(json?.data?.tokens?.accessToken).to.be.a('string'); });",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('driverUserId', json.data.user.id);",
                  "if (json?.data?.user?.firstName && json?.data?.user?.lastName) pm.collectionVariables.set('driverName', `${json.data.user.firstName} ${json.data.user.lastName}`);",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('driverAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('driverRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{approvedDriverEmail}}\",\n  \"password\": \"{{seedPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Dang nhap bang driver seed san. Day la driver da APPROVED, vi vay co the online, nhan ride va xem earnings ngay."
          }
        },
        {
          "name": "Get Current Driver Profile",
          "event": [
