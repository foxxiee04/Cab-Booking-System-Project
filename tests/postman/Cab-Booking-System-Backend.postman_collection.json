              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Ride created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const ride = json?.data?.ride;",
                  "if (ride?.id) pm.collectionVariables.set('rideId', ride.id);",
                  "const fare = ride?.fare || ride?.estimatedFare || 120000;",
                  "pm.collectionVariables.set('rideFare', String(fare));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
