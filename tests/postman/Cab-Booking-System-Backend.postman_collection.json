    {
      "name": "06 - Payments",
      "description": "Test payment-service xoay quanh ride vua complete: methods, payment intent, mock webhook, query by ride va history/earnings.",
      "item": [
        {
          "name": "Get Payment Methods",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/payments/methods",
            "description": "Lay danh sach phuong thuc thanh toan backend dang expose."
          }
        },
        {
          "name": "Create Payment Intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Payment intent created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const payload = json?.data || {};",
                  "pm.test('Payment intent id captured', function () { pm.expect(payload.paymentIntentId).to.be.a('string'); });",
                  "if (payload.paymentIntentId) pm.collectionVariables.set('paymentIntentId', payload.paymentIntentId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" },
              { "key": "Idempotency-Key", "value": "pm-{{runId}}-ride-{{rideId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"amount\": {{rideFare}},\n  \"currency\": \"VND\",\n  \"paymentMethod\": \"CARD\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/intents",
            "description": "Tao payment intent cho ride vua hoan tat. Idempotency-Key duoc gan theo runId va rideId de tranh duplicate intent."
          }
        },
