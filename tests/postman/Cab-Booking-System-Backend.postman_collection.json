    {
      "name": "01 - Customer Auth",
      "description": "Tao customer moi cho lan test hien tai, dang nhap, refresh token va doc thong tin nguoi dung hien tai.",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer registered', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "pm.test('Customer access token stored', function () { pm.expect(json?.data?.tokens?.accessToken).to.be.a('string'); });",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('customerUserId', json.data.user.id);",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Customer\",\n  \"phone\": \"{{customerPhone}}\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Dang ky customer moi. Collection co y dung phone sinh theo runId de tranh loi unique constraint khi chay nhieu lan."
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer login OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Customer refresh token exists', function () { pm.expect(json?.data?.tokens?.refreshToken).to.be.a('string'); });",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('customerUserId', json.data.user.id);",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Dang nhap lai customer vua tao de chac chan auth flow va JWT cap lai dang hoat dong dung."
          }
        },
        {
          "name": "Refresh Customer Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer refresh OK', function () { pm.response.to.have.status(200); });",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{customerRefreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "Doi access token moi tu refresh token vua luu. Neu request nay fail, cac request auth sau do co the cung fail day chuyen."
          }
        },
        {
          "name": "Get Current Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Doc lai thong tin customer hien tai bang access token de xac nhan token co quyen hop le."
          }
        }
      ]
