        {
          "name": "Create Review For Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Review created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const review = json?.review || json?.data?.review;",
                  "pm.test('Review id captured when returned', function () { pm.expect(review?._id || review?.id || true).to.be.ok; });",
                  "if (review?._id) pm.collectionVariables.set('reviewId', review._id);",
                  "if (review?.id) pm.collectionVariables.set('reviewId', review.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" },
