      "name": "00 - Bootstrap",
      "item": [
        {
          "name": "Init Test Variables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('customerEmail', `postman.customer.${runId}@example.com`);",
                  "pm.collectionVariables.set('driverEmail', `postman.driver.${runId}@example.com`);",
                  "pm.collectionVariables.unset('customerAccessToken');",
                  "pm.collectionVariables.unset('customerRefreshToken');",
                  "pm.collectionVariables.unset('driverAccessToken');",
                  "pm.collectionVariables.unset('driverRefreshToken');",
                  "pm.collectionVariables.unset('customerUserId');",
                  "pm.collectionVariables.unset('driverUserId');",
                  "pm.collectionVariables.unset('driverProfileId');",
                  "pm.collectionVariables.unset('bookingId');",
                  "pm.collectionVariables.unset('rideId');",
                  "pm.collectionVariables.set('rideFare', '120000');",
                  "pm.collectionVariables.unset('paymentIntentId');",
                  "pm.collectionVariables.unset('reviewId');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway health OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Khoi tao email/token/id moi cho mot lan chay collection. Chay request nay dau tien."
