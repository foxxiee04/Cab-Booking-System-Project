        },
        {
          "name": "Create Payment Intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Payment intent created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const payload = json?.data || {};",
                  "if (payload.paymentIntentId) pm.collectionVariables.set('paymentIntentId', payload.paymentIntentId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" },
              { "key": "Idempotency-Key", "value": "pm-{{runId}}-ride-{{rideId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"amount\": {{rideFare}},\n  \"currency\": \"VND\",\n  \"paymentMethod\": \"CARD\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/intents"
          }
        },
        {
          "name": "Mock Payment Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentIntentId\": \"{{paymentIntentId}}\",\n  \"status\": \"COMPLETED\",\n  \"transactionId\": \"txn-{{runId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/webhook/mock"
          }
        },
