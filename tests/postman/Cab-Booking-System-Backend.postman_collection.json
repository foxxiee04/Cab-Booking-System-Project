    {
      "name": "01 - Customer Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer registered', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('customerUserId', json.data.user.id);",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Customer\",\n  \"phone\": \"0901234567\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer login OK', function () { pm.response.to.have.status(200); });",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('customerUserId', json.data.user.id);",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh Customer Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer refresh OK', function () { pm.response.to.have.status(200); });",
                  "if (json?.data?.tokens?.accessToken) pm.collectionVariables.set('customerAccessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.collectionVariables.set('customerRefreshToken', json.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
