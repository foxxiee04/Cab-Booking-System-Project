            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{customerUserId}}\",\n  \"type\": \"IN_APP\",\n  \"recipient\": \"{{customerEmail}}\",\n  \"subject\": \"Ride completed\",\n  \"message\": \"Your ride {{rideId}} has been completed successfully.\",\n  \"priority\": \"HIGH\",\n  \"metadata\": {\n    \"rideId\": \"{{rideId}}\",\n    \"bookingId\": \"{{bookingId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/notifications/notifications/send"
          }
        },
        {
          "name": "Get Customer Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/notifications/notifications?limit=20"
          }
        },
        {
          "name": "Create Review For Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Review created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const review = json?.review || json?.data?.review;",
                  "if (review?._id) pm.collectionVariables.set('reviewId', review._id);",
                  "if (review?.id) pm.collectionVariables.set('reviewId', review.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" },
              { "key": "x-user-name", "value": "{{customerName}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"bookingId\": \"{{bookingId}}\",\n  \"type\": \"CUSTOMER_TO_DRIVER\",\n  \"revieweeId\": \"{{driverUserId}}\",\n  \"revieweeName\": \"{{driverName}}\",\n  \"rating\": 5,\n  \"comment\": \"Tai xe den dung gio, di chuyen an toan.\",\n  \"tags\": [\"professional\", \"safe_driving\"]\n}"
            },
            "url": "{{baseUrl}}/api/reviews/reviews"
          }
        },
        {
          "name": "Get Ride Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/reviews/reviews/ride/{{rideId}}"
          }
        },
        {
          "name": "Get Driver Review Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/reviews/reviews/driver/{{driverUserId}}/stats"
          }
        }
      ]
    },
