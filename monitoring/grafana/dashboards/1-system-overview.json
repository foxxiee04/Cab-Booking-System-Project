{
  "title": "System Overview",
  "uid": "system-overview",
  "tags": ["system", "node"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
        "legendFormat": "Memory %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        }
      }
    },
    {
      "id": 3,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
        "legendFormat": "Disk %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "time() - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "TX {{device}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 6,
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "targets": [
        { "datasource": "Prometheus", "expr": "node_load1", "legendFormat": "1m" },
        { "datasource": "Prometheus", "expr": "node_load5", "legendFormat": "5m" },
        { "datasource": "Prometheus", "expr": "node_load15", "legendFormat": "15m" }
      ]
    },
    {
      "id": 7,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes - node_memory_MemFree_bytes - node_memory_Buffers_bytes - node_memory_Cached_bytes", "legendFormat": "Used" },
        { "datasource": "Prometheus", "expr": "node_memory_Cached_bytes", "legendFormat": "Cached" },
        { "datasource": "Prometheus", "expr": "node_memory_Buffers_bytes", "legendFormat": "Buffers" },
        { "datasource": "Prometheus", "expr": "node_memory_MemFree_bytes", "legendFormat": "Free" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "schemaVersion": 38
}
