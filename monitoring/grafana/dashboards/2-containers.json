{
  "title": "Container Resources",
  "uid": "containers",
  "tags": ["docker", "containers"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Running Containers",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "count(container_last_seen{name!~\".*POD.*\",name!=\"\"})",
        "legendFormat": "Containers"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 2,
      "title": "Total Container CPU %",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(container_cpu_usage_seconds_total{name!~\".*POD.*\",name!=\"\"}[5m])) * 100",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 3,
      "title": "Total Container Memory",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(container_memory_working_set_bytes{name!~\".*POD.*\",name!=\"\"})",
        "legendFormat": "Memory"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "CPU Usage per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sort_desc(sum by (name) (rate(container_cpu_usage_seconds_total{name!~\".*POD.*|cab-prometheus|cab-grafana|cab-loki|cab-promtail|cab-cadvisor\",name!=\"\"}[5m])) * 100)",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "title": "Memory Usage per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 9 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sort_desc(sum by (name) (container_memory_working_set_bytes{name!~\".*POD.*|cab-prometheus|cab-grafana|cab-loki|cab-promtail|cab-cadvisor\",name!=\"\"}))",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "title": "Container Restarts",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "increase(container_last_seen{name!~\".*POD.*\",name!=\"\"}[10m])",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "id": 7,
      "title": "Network I/O per Container",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!~\".*POD.*\",name!=\"\"}[5m]))",
          "legendFormat": "RX {{name}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!~\".*POD.*\",name!=\"\"}[5m]))",
          "legendFormat": "TX {{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "schemaVersion": 38
}
