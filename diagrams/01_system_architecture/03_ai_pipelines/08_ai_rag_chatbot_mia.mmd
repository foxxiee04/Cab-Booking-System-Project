flowchart LR
  Docs["FoxGo knowledge<br/>booking, pricing, payment, wallet, cancellation, driver"]:::data
  Chunk["Chunking<br/>tách đoạn + Q&A"]:::service
  DocVector["Document embedding vector<br/>Vietnamese bi-encoder"]:::ai
  VectorIndex[("Vector index<br/>FAISS vectors + BM25 keywords")]:::data

  User["User question<br/>message + history"]:::user
  Rewrite["Rewrite / smalltalk<br/>làm rõ câu hỏi mơ hồ"]:::service
  QueryVector["Query embedding vector<br/>biến câu hỏi thành vector"]:::ai
  Retrieve["Hybrid retrieval<br/>vector cosine + keyword + RRF"]:::ai
  Rerank["Rerank top context<br/>BGE cross-encoder"]:::ai
  Prompt["Grounded prompt<br/>context + persona Mia"]:::ai
  LLM["LLM provider<br/>OpenAI -> Gemini API key"]:::external
  Answer["Answer<br/>sources, mode, score_max"]:::service
  Fallback["Fallback<br/>Q&A, template, hỏi lại, hotline/email"]:::ok

  Docs --> Chunk --> DocVector --> VectorIndex
  User --> Rewrite --> QueryVector --> Retrieve --> Rerank --> Prompt --> LLM --> Answer
  VectorIndex --> Retrieve
  Prompt -. "score thấp / thiếu key / LLM lỗi" .-> Fallback --> Answer

