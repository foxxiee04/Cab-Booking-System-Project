flowchart LR
  Request["Yêu cầu đặt xe<br/>pickup, dropoff, loại xe, thời điểm"]:::user
  Features["Feature builder<br/>quãng đường, thời gian, khu vực<br/>demand/supply, pool tài xế"]:::service
  AI["AI Service<br/>ETA + Surge: RandomForest eta-rf-v2<br/>P_accept: GradientBoosting accept-gbm-v1<br/>Wait-time: GBR wait-gbr-v1"]:::ai

  Price["Báo giá<br/>base + loại xe + km + phút + surge<br/>Output: fare, ETA, wait_time"]:::service
  Dispatch["Xếp hạng tài xế<br/>ETA, rating, accept, cancel, idle, priority × P_accept<br/>Output: driver ranking"]:::service
  Result["Kết quả giải thích được<br/>fare, tài xế ưu tiên, score_breakdown, reason_code"]:::data

  Fallback["Fallback rule-based<br/>AI timeout/lỗi: giá cố định, Redis GEO, P_accept = 1.0"]:::ok

  Request --> Features --> AI
  AI --> Price
  AI --> Dispatch
  Price --> Result
  Dispatch --> Result
  Features -. "AI không sẵn sàng" .-> Fallback --> Result

