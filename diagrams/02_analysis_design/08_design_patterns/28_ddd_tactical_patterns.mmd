    Repository["Repository interface"]:::service
    Mapper["DTO mapper"]:::infra
  end

  RideAgg --> Entity
  WalletAgg --> ValueObject
  PaymentAgg --> DomainEvent
  UseCase --> Aggregate
  UseCase --> Repository
  UseCase --> Mapper
