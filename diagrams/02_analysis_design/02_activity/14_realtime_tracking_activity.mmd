flowchart LR
  subgraph DriverApp["Actor: Driver App"]
    direction TB
    Start([Ride active]):::user
    JoinRoom["Join ride socket room"]:::service
    SendGps["Send GPS update"]:::service
    FixGps["Correct invalid GPS or reconnect"]:::risk
    Stop["Stop tracking when ride closes"]:::ok
  end

  subgraph Realtime["System: Realtime Gateway"]
    direction TB
    AuthRoom{"Participant and ride room valid?"}:::security
    Deny["Reject unauthorized socket event"]:::risk
    Validate{"GPS format, speed, timestamp valid?"}:::infra
    RideActive{"Ride still active?"}:::infra
    Store["Store latest location in Redis and ride trail"]:::data
    Broadcast["Broadcast location to customer room"]:::external
    Ack{"Client acknowledged or reconnecting?"}:::infra
    Queue["Keep latest state for reconnect"]:::service
    Done([End]):::ok
  end

  Start --> JoinRoom --> AuthRoom
  AuthRoom -- No --> Deny --> Done
  AuthRoom -- Yes --> SendGps --> Validate
  Validate -- No --> FixGps --> SendGps
  Validate -- Yes --> RideActive
  RideActive -- No --> Stop --> Done
  RideActive -- Yes --> Store --> Broadcast --> Ack
  Ack -- No --> Queue --> SendGps
  Ack -- Yes --> SendGps
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
classDef service fill:#ccfbf1,stroke:#14b8a6,color:#0f172a,stroke-width:1.5px;
classDef data fill:#dcfce7,stroke:#22c55e,color:#0f172a,stroke-width:1.5px;
