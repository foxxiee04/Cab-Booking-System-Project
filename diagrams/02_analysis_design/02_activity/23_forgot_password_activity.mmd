flowchart LR
  subgraph User["Actor: Customer / Driver / Admin"]
    direction TB
    Start([Start]):::user
    OpenForgot["Open forgot password screen"]:::service
    EnterPhone["Enter registered phone number"]:::service
    EnterOtp["Enter OTP code"]:::service
    SetPassword["Enter new password and confirmation"]:::service
    FixInput["Fix phone, OTP, or password validation"]:::risk
    LoginAgain["Login with new password"]:::ok
  end

  subgraph Auth["System: Auth Service"]
    direction TB
    FindUser{"Account exists and active?"}:::security
    Deny["Show generic recovery message"]:::risk
    IssueOtp["Create password reset OTP"]:::data
    SendOtp["Send OTP through SMS/mock provider"]:::external
    OtpValid{"OTP valid and not expired?"}:::infra
    PasswordValid{"Password policy satisfied?"}:::infra
    UpdateHash["Hash new password and revoke old sessions"]:::data
    Audit["Write password reset audit log"]:::data
    Done([End]):::ok
  end

  Start --> OpenForgot --> EnterPhone --> FindUser
  FindUser -- No --> Deny --> Done
  FindUser -- Yes --> IssueOtp --> SendOtp --> EnterOtp --> OtpValid
  OtpValid -- No --> FixInput --> EnterOtp
  OtpValid -- Yes --> SetPassword --> PasswordValid
  PasswordValid -- No --> FixInput --> SetPassword
  PasswordValid -- Yes --> UpdateHash --> Audit --> LoginAgain --> Done
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
classDef service fill:#ccfbf1,stroke:#14b8a6,color:#0f172a,stroke-width:1.5px;
classDef data fill:#dcfce7,stroke:#22c55e,color:#0f172a,stroke-width:1.5px;
classDef ai fill:#fef3c7,stroke:#f59e0b,color:#0f172a,stroke-width:1.5px;
classDef infra fill:#e0e7ff,stroke:#818cf8,color:#0f172a,stroke-width:1.5px;
classDef external fill:#ffedd5,stroke:#fb923c,color:#0f172a,stroke-width:1.5px;
classDef risk fill:#fee2e2,stroke:#ef4444,color:#0f172a,stroke-width:1.5px;
classDef ok fill:#bbf7d0,stroke:#22c55e,color:#0f172a,stroke-width:1.5px;
classDef pattern fill:#f5d0fe,stroke:#d946ef,color:#0f172a,stroke-width:1.5px;
classDef security fill:#dbeafe,stroke:#2563eb,color:#0f172a,stroke-width:1.5px;
