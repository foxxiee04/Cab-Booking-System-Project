flowchart LR
  subgraph User["Actor: Authenticated User"]
    direction TB
    Start([Start]):::user
    ClickLogout["Click logout"]:::service
    Confirm{"Confirm logout?"}:::infra
    Stay["Stay in current session"]:::ok
    ViewLogin["Return to login screen"]:::ok
  end

  subgraph Auth["System: Client / API Gateway / Auth Service"]
    direction TB
    TokenPresent{"Refresh token exists?"}:::security
    Revoke["Revoke refresh token in auth_db"]:::data
    ClearClient["Clear access token, refresh token, user cache"]:::data
    LeaveRooms["Leave Socket.IO rooms and disconnect realtime session"]:::service
    Audit["Write logout audit event"]:::data
    Done([End]):::ok
  end

  Start --> ClickLogout --> Confirm
  Confirm -- No --> Stay --> Done
  Confirm -- Yes --> TokenPresent
  TokenPresent -- Yes --> Revoke --> ClearClient
  TokenPresent -- No --> ClearClient
  ClearClient --> LeaveRooms --> Audit --> ViewLogin --> Done
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
classDef service fill:#ccfbf1,stroke:#14b8a6,color:#0f172a,stroke-width:1.5px;
