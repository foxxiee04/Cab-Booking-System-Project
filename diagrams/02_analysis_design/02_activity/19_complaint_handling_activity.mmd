flowchart LR
  subgraph User["Actor: Customer / Driver"]
    direction TB
    Start([Start]):::user
    Submit["Submit complaint, category, evidence"]:::service
    FixComplaint["Fix category, note length, or attachment"]:::risk
    Track["Track complaint status"]:::service
    Receive["Receive support resolution"]:::ok
  end

  subgraph Support["System: Support / Admin"]
    direction TB
    Auth{"Requester belongs to ride or account?"}:::security
    Deny["Reject unauthorized complaint"]:::risk
    Validate{"Required fields and evidence format valid?"}:::infra
    Duplicate{"Duplicate open complaint?"}:::infra
    LinkCase["Link ride, payment, chat, and review evidence"]:::data
    Review["Admin reviews case and contacts parties"]:::service
    Action{"Refund, warning, lock, or no action?"}:::infra
    Execute["Execute selected action and audit"]:::data
    Close["Close complaint with reason"]:::ok
    Done([End]):::ok
  end

  Start --> Submit --> Auth
  Auth -- No --> Deny --> Done
  Auth -- Yes --> Validate
  Validate -- No --> FixComplaint --> Submit
  Validate -- Yes --> Duplicate
  Duplicate -- Yes --> Track --> Done
  Duplicate -- No --> LinkCase --> Review --> Action --> Execute --> Close --> Receive --> Done
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
