flowchart LR
  subgraph RideActors["Actor: Customer / Driver"]
    direction TB
    Start([Start]):::user
    ChooseCash["Customer chooses cash payment"]:::service
    CompleteRide["Driver completes ride and collects cash"]:::service
    ViewDebt["Driver views platform fee debt"]:::service
    TopupOrSettle["Top up wallet or wait for FIFO settlement"]:::service
  end

  subgraph Finance["System: Payment / Wallet"]
    direction TB
    RegisterDeferred["Register deferred cash payment"]:::data
    DispatchGate["Allow driver matching without online checkout"]:::ok
    RideDone{"Ride completed?"}:::infra
    CalculateFee["Calculate fare, commission, discount, platform fee"]:::service
    CreateEarning["Record driver earning as cash collected"]:::data
    CreateDebt["Create DebtRecord for platform commission"]:::data
    WalletEnough{"Wallet has available balance?"}:::infra
    SettleDebt["Settle oldest debt by FIFO"]:::data
    KeepDebt["Keep debt open and restrict by policy if needed"]:::risk
    Publish["Publish payment.finalized and debt.updated"]:::external
    Done([End]):::ok
  end

  Start --> ChooseCash --> RegisterDeferred --> DispatchGate --> CompleteRide --> RideDone
  RideDone -- No --> Done
  RideDone -- Yes --> CalculateFee --> CreateEarning --> CreateDebt --> WalletEnough
  WalletEnough -- Yes --> SettleDebt --> Publish --> ViewDebt --> Done
  WalletEnough -- No --> KeepDebt --> Publish --> ViewDebt --> TopupOrSettle --> Done
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
classDef service fill:#ccfbf1,stroke:#14b8a6,color:#0f172a,stroke-width:1.5px;
classDef data fill:#dcfce7,stroke:#22c55e,color:#0f172a,stroke-width:1.5px;
classDef ai fill:#fef3c7,stroke:#f59e0b,color:#0f172a,stroke-width:1.5px;
classDef infra fill:#e0e7ff,stroke:#818cf8,color:#0f172a,stroke-width:1.5px;
classDef external fill:#ffedd5,stroke:#fb923c,color:#0f172a,stroke-width:1.5px;
classDef risk fill:#fee2e2,stroke:#ef4444,color:#0f172a,stroke-width:1.5px;
classDef ok fill:#bbf7d0,stroke:#22c55e,color:#0f172a,stroke-width:1.5px;
classDef pattern fill:#f5d0fe,stroke:#d946ef,color:#0f172a,stroke-width:1.5px;
