flowchart LR
  subgraph UserApp["Actor: Customer / Driver"]
    direction TB
    Start([Ride assigned]):::user
    Compose["Compose chat message or call request"]:::service
    FixMessage["Fix empty text, length, or attachment format"]:::risk
    Receive["Receive realtime message or push notification"]:::service
    EndCall["End chat/call session"]:::ok
  end

  subgraph RealtimeNotify["System: Gateway / Notification"]
    direction TB
    Participant{"Sender belongs to active ride?"}:::security
    Deny["Reject unauthorized room access"]:::risk
    Validate{"Payload valid and safe?"}:::infra
    Store["Store message/call metadata"]:::data
    Online{"Recipient online in socket room?"}:::infra
    SocketSend["Emit Socket.IO event"]:::external
    PushSend["Send push/SMS/email fallback"]:::external
    Delivered{"Delivery acknowledged?"}:::infra
    Record["Record delivery status"]:::data
    Done([End]):::ok
  end

  Start --> Compose --> Participant
  Participant -- No --> Deny --> Done
  Participant -- Yes --> Validate
  Validate -- No --> FixMessage --> Compose
  Validate -- Yes --> Store --> Online
  Online -- Yes --> SocketSend --> Delivered
  Online -- No --> PushSend --> Delivered
  Delivered -- No --> Record --> PushSend
  Delivered -- Yes --> Receive --> Record --> EndCall --> Done
classDef user fill:#dbeafe,stroke:#60a5fa,color:#0f172a,stroke-width:1.5px;
