flowchart LR
  subgraph Scheduler["Actor: Scheduler"]
    direction TB
    Start([T+24h schedule]):::user
    LoadHolds["Load matured held earnings"]:::service
    ValidateBatch{"Batch window and lock valid?"}:::infra
    Retry["Retry later and alert ops"]:::risk
    Process["Process each matured hold"]:::service
  end

  subgraph Wallet["System: Wallet Service"]
    direction TB
    HoldValid{"Hold not settled, not disputed,<br/>driver wallet active?"}:::infra
    Skip["Skip disputed, inactive, or duplicate hold"]:::risk
    MoveFunds["Move held balance to available balance"]:::data
    Ledger["Write settlement ledger entry"]:::data
    Publish["Publish wallet.settled event"]:::external
    Notify["Notify driver that earning is available"]:::external
    Done([End]):::ok
  end

  Start --> LoadHolds --> ValidateBatch
  ValidateBatch -- No --> Retry --> Done
  ValidateBatch -- Yes --> Process --> HoldValid
  HoldValid -- No --> Skip --> Process
  HoldValid -- Yes --> MoveFunds --> Ledger --> Publish --> Notify --> Process
  Process -. no more holds .-> Done
