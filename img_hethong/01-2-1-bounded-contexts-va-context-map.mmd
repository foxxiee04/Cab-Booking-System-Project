        RL["RideLocation"]
        RE["RideStateTransition"]
        R --- RL
        R --- RE
    end

    subgraph DRC["Driver Management\ndriver-service"]
        DV["Driver (AR)\nstatus · rating · geo"]
        DL["DriverLocation"]
        DLI["DriverLicense"]
        DV --- DL
        DV --- DLI
    end

    subgraph BC["Booking\nbooking-service"]
        BK["Booking (AR)"]
    end

    subgraph PRC["Pricing\npricing-service"]
        PQ["PricingQuery (VO)"]
        SR["SurgeRate (VO)"]
