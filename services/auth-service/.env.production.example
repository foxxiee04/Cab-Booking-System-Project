# =============================================================
# Auth Service — Production Environment Variables
# Copy to .env and fill in your values before deploying to AWS
# =============================================================

PORT=3001
GRPC_PORT=50051
NODE_ENV=production
SERVICE_NAME=auth-service

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOURPASSWORD@your-rds-host:5432/auth_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://your-elasticache-host:6379

# ─── JWT (generate via: openssl rand -hex 64) ────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@your-rabbitmq-host:5672

# ─── Internal service auth ───────────────────────────────────
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# ─── OTP settings ────────────────────────────────────────────
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RATE_MAX_PER_PHONE=3
OTP_RATE_PHONE_WINDOW=600
OTP_RATE_MAX_PER_IP=10
OTP_RATE_IP_WINDOW=60

# =============================================================
# OTP_SMS_MODE — chọn 1 trong 4 chế độ:
#
#  mock      → In OTP ra log container (chỉ dùng khi dev/test)
#  twilio    → Gửi SMS qua Twilio (hoạt động quốc tế, ~$0.0075/tin)
#  speedsms  → Gửi SMS qua SpeedSMS VN (số Việt Nam, ~100đ/tin, ổn định hơn)
#  sns       → Gửi SMS qua AWS SNS (cần IAM role sns:Publish, ~$0.065/tin)
# =============================================================
OTP_SMS_MODE=speedsms

# ─── Option 1: Twilio ─────────────────────────────────────────
# Đăng ký tại https://www.twilio.com — free trial có $15 credit
# Console: https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_PHONE=+84xxxxxxxxx   (mua số ảo tại Twilio)

# ─── Option 2: SpeedSMS (khuyến nghị cho thesis Việt Nam) ────
# Đăng ký tại https://speedsms.vn — nạp ~50.000đ là dùng được
# API key ở: Tài khoản > API > API Access Token
SPEEDSMS_API_KEY=your_speedsms_api_key
# SPEEDSMS_SENDER=CabBook   (tên hiện thị, cần đăng ký riêng — để trống nếu chưa có)

# ─── Option 3: AWS SNS ────────────────────────────────────────
# Trên EC2/ECS: gắn IAM Role có policy sns:Publish — không cần key
# Chạy local: cần set 3 biến sau
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your_secret
# Lưu ý: AWS SNS Sandbox mặc định chỉ gửi được cho số đã verify.
#         Cần request "production access" trong SNS console để gửi tự do.
