# AI Service Configuration

# ── Service settings ───────────────────────────────────────────────────────
APP_NAME=AI Prediction Service
APP_VERSION=1.1.0
DEBUG=False

# ── Server settings ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── ML model paths ─────────────────────────────────────────────────────────
MODEL_PATH=app/models/eta_price_model.joblib
ACCEPT_MODEL_PATH=app/models/accept_model.joblib
WAIT_MODEL_PATH=app/models/wait_model.joblib

# ── RAG Chatbot — LLM provider ────────────────────────────────────────────
# Priority: claude > groq > gemini > openai > friendly template fallback
# Set RAG_LLM_PROVIDER=auto to try all in order, or specify one explicitly (gemini | groq | claude | openai).
#
# Recommended: Claude (most human-like, Vietnamese comprehension excellent).
# Cheapest production-quality combo: gemini-2.5-flash with groq fallback.
RAG_LLM_PROVIDER=auto
RAG_LLM_MODEL_CLAUDE=claude-haiku-4-5-20251001

# Get your Anthropic key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (free tier, fast) — https://console.groq.com/
# llama-3.3-70b-versatile is the current free tier flagship (much better than llama3-8b).
GROQ_API_KEY=
RAG_LLM_MODEL=llama-3.3-70b-versatile

# OpenAI fallback (gpt-4o-mini is cheaper + smarter than gpt-3.5-turbo)
OPENAI_API_KEY=
RAG_LLM_MODEL_OPENAI=gpt-4o-mini

# Google Gemini (AI Studio API key) — https://aistudio.google.com/apikey
# Cost-effective: set RAG_LLM_PROVIDER=gemini if Gemini is your only key.
# Upgraded default: gemini-2.5-flash (much smarter than 2.0-flash, similar latency).
# For maximum accuracy use gemini-2.5-pro (slower, higher quality).
GEMINI_API_KEY=
RAG_LLM_MODEL_GEMINI=gemini-2.5-flash
# Lightweight model just for pre-retrieval query rewriting (cheap, fast).
RAG_LLM_MODEL_GEMINI_REWRITE=gemini-2.5-flash

# ── RAG tuning ─────────────────────────────────────────────────────────────
RAG_LLM_TIMEOUT_S=20
RAG_LLM_REWRITE_TIMEOUT_S=6
RAG_LLM_MAX_TOKENS=900
RAG_LLM_TEMPERATURE=0.25
# Cosine gating (0–1, normalized embeddings). RRF scores are NOT cosines — do not mix.
# Below RAG_COSINE_ABSENT → refuse (avoid wrong answers). Between ABSENT and LLM → excerpt only.
RAG_COSINE_ABSENT=0.22
RAG_COSINE_LLM=0.30
RAG_FAISS_PREFILTER=0.16
RAG_MIN_SEMANTIC=0.35
# Số chunk retrieval mặc định khi client không gửi top_k (1–16 trong ChatRequest).
RAG_TOP_K=8
# Embedding model — Vietnamese-tuned bi-encoder (PhoBERT-based, 768 dim).
# Alternatives:
#   intfloat/multilingual-e5-base   (auto-applies "query:"/"passage:" prefixes)
#   intfloat/multilingual-e5-large  (heavier, ~1.1 GB)
#   paraphrase-multilingual-MiniLM-L12-v2  (legacy, smaller/lower accuracy)
RAG_EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder
# Giới hạn ký tự ghép "NGỮ CẢNH TÌM ĐƯỢC" gửi LLM (tăng khi top_k lớn / tài liệu dài).
RAG_MAX_CONTEXT_CHARS=6400

# ── Cross-encoder reranker (accuracy booster) ─────────────────────────────
# After hybrid (FAISS + BM25) retrieval, rerank the top-N candidates with a
# cross-encoder to dramatically improve precision (+15-30% on Vietnamese RAG).
# Downloads ~568 MB on first run, then cached. Set to "false" to disable.
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# How many hybrid candidates to feed the reranker before trimming to top_k.
RAG_RERANK_POOL=20

# ── LLM query rewriting (pre-retrieval) ───────────────────────────────────
# Use Gemini Flash to rewrite ambiguous/short queries ("vậy thì sao", "nó",
# "ơi", "thế còn") into clean search queries before embedding. Adds 1 cheap
# API call but materially improves recall on real chat traffic.
# Auto-triggers only on short / follow-up / very long queries — not every turn.
RAG_QUERY_REWRITE_ENABLED=true

# ── Background maintenance (optional) ─────────────────────────────────────
# 3600 = mỗi giờ (ổn khi dev sửa FAQ liên tục). Production/Swarm: 86400 (24h) hoặc 0
# và chỉ cập nhật tri thức khi deploy / POST /api/internal/refresh.
AI_AUTO_RELOAD_RAG_SEC=0
#
# ML: re-run training/train_*.py then hot-reload joblibs — expensive on CPU.
AI_AUTO_RETRAIN_SEC=0
AI_AUTO_RETRAIN_ENABLED=false
#
# POST /api/internal/refresh  →  Authorization: Bearer <token>
# Leave empty to hide the route (404).
AI_INTERNAL_TOKEN=
