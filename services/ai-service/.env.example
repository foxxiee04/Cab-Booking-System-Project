# AI Service Configuration

# ── Service settings ───────────────────────────────────────────────────────
APP_NAME=AI Prediction Service
APP_VERSION=1.1.0
DEBUG=False

# ── Server settings ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── ML model paths ─────────────────────────────────────────────────────────
MODEL_PATH=app/models/eta_price_model.joblib
ACCEPT_MODEL_PATH=app/models/accept_model.joblib
WAIT_MODEL_PATH=app/models/wait_model.joblib

# ── RAG Chatbot — LLM provider ────────────────────────────────────────────
# Priority: claude > groq > gemini > openai > template fallback
# Set RAG_LLM_PROVIDER=auto to try all in order, or specify one explicitly (gemini | groq | claude | openai).
#
# Recommended: Claude (most human-like, Vietnamese comprehension excellent)
RAG_LLM_PROVIDER=auto
RAG_LLM_MODEL_CLAUDE=claude-haiku-4-5-20251001

# Get your Anthropic key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (free tier, fast) — https://console.groq.com/
GROQ_API_KEY=
RAG_LLM_MODEL=llama3-8b-8192

# OpenAI fallback
OPENAI_API_KEY=
RAG_LLM_MODEL_OPENAI=gpt-3.5-turbo

# Google Gemini (AI Studio API key) — https://aistudio.google.com/apikey
# Tiết kiệm chi phí: đặt RAG_LLM_PROVIDER=gemini hoặc chỉ cấu hình GEMINI_API_KEY (và tắt key khác).
GEMINI_API_KEY=
# Ví dụ: gemini-2.0-flash | gemini-1.5-flash (ổn định trên API v1beta)
RAG_LLM_MODEL_GEMINI=gemini-2.0-flash

# ── RAG tuning ─────────────────────────────────────────────────────────────
RAG_LLM_TIMEOUT_S=14
RAG_LLM_MAX_TOKENS=768
RAG_LLM_TEMPERATURE=0.22
# Cosine gating (0–1, normalized embeddings). RRF scores are NOT cosines — do not mix.
# Below RAG_COSINE_ABSENT → refuse (avoid wrong answers). Between ABSENT and LLM → excerpt only.
RAG_COSINE_ABSENT=0.22
RAG_COSINE_LLM=0.30
RAG_FAISS_PREFILTER=0.16
RAG_MIN_SEMANTIC=0.35
# Số chunk retrieval mặc định khi client không gửi top_k (1–16 trong ChatRequest).
RAG_TOP_K=8
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Giới hạn ký tự ghép "NGỮ CẢNH TÌM ĐƯỢC" gửi LLM (tăng khi top_k lớn / tài liệu dài).
RAG_MAX_CONTEXT_CHARS=6400

# ── Background maintenance (optional) ─────────────────────────────────────
# 3600 = mỗi giờ (ổn khi dev sửa FAQ liên tục). Production/Swarm: 86400 (24h) hoặc 0
# và chỉ cập nhật tri thức khi deploy / POST /api/internal/refresh.
AI_AUTO_RELOAD_RAG_SEC=0
#
# ML: re-run training/train_*.py then hot-reload joblibs — expensive on CPU.
AI_AUTO_RETRAIN_SEC=0
AI_AUTO_RETRAIN_ENABLED=false
#
# POST /api/internal/refresh  →  Authorization: Bearer <token>
# Leave empty to hide the route (404).
AI_INTERNAL_TOKEN=
