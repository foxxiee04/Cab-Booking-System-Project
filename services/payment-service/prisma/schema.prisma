generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  REQUIRES_ACTION
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  MOMO
  VNPAY
  VISA
}

enum PaymentProvider {
  STRIPE
  MOCK
  MOMO
  VNPAY
  VISA
  ZALOPAY
}

model Fare {
  id              String    @id @default(uuid())
  rideId          String    @unique
  
  baseFare        Float
  distanceFare    Float
  timeFare        Float
  surgeMultiplier Float     @default(1.0)
  totalFare       Float
  
  distanceKm      Float
  durationMinutes Int
  
  currency        String    @default("VND")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id              String        @id @default(uuid())
  rideId          String        @unique
  customerId      String
  driverId        String?
  
  amount          Float
  currency        String        @default("VND")
  
  method          PaymentMethod @default(CASH)
  provider        PaymentProvider @default(MOCK)
  status          PaymentStatus @default(PENDING)
  
  // Transaction details
  transactionId   String?
  paymentIntentId String?
  paymentMethodId String?
  clientSecret    String?
  idempotencyKey  String?
  gatewayResponse String?
  metadata        Json?
  
  // Timestamps
  initiatedAt     DateTime      @default(now())
  completedAt     DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  
  failureReason   String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([customerId, createdAt(sort: Desc)])
  @@index([driverId, createdAt(sort: Desc)])
  @@index([status])
  @@index([idempotencyKey])
}

// Per-trip earnings record for the driver
// Created inside the same transaction as Fare + Payment when a ride completes.
model DriverEarnings {
  id              String   @id @default(uuid())

  // Identifiers
  rideId          String   @unique
  driverId        String

  // Fare components (VND)
  grossFare       Float                      // full fare charged to customer
  commissionRate  Float                      // effective rate, e.g. 0.18
  platformFee     Float                      // grossFare × commissionRate (rounded)

  // Adjustments (VND)
  bonus           Float    @default(0)       // total incentive bonus
  penalty         Float    @default(0)       // total penalty deduction

  // Net result (VND)
  netEarnings     Float                      // grossFare − platformFee + bonus − penalty

  // Payment accounting
  paymentMethod   String                     // CASH | MOMO | VNPAY | …
  driverCollected Boolean  @default(false)   // true = driver collected cash from rider
  cashDebt        Float    @default(0)       // VND driver owes platform (cash rides only)

  // Payout tracking
  isPaid          Boolean  @default(false)
  paidAt          DateTime?

  // JSON breakdown for audit trail
  bonusBreakdown   Json?                     // { peakHour: 15000, tripMilestone: 50000, … }
  penaltyBreakdown Json?                     // { highCancelRate: 3000, … }

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([driverId, createdAt(sort: Desc)])
  @@index([driverId, isPaid])
}

// Outbox pattern for reliable event publishing
model OutboxEvent {
  id            String    @id @default(uuid())
  eventType     String
  payload       String    // JSON string
  correlationId String
  
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?
  
  @@index([publishedAt])
}
