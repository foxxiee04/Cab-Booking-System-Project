    {
      "name": "🗺️ Booking Flow — Customer",
      "item": [
        {
          "name": "1. Ước tính giá (Pricing)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup\": {\n    \"lat\": 10.7769,\n    \"lng\": 106.7009,\n    \"address\": \"Quận 1, TP.HCM\"\n  },\n  \"dropoff\": {\n    \"lat\": 10.8231,\n    \"lng\": 106.6297,\n    \"address\": \"Tân Bình, TP.HCM\"\n  },\n  \"vehicleType\": \"MOTORBIKE\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/pricing/estimate", "host": ["{{base_url}}"], "path": ["api","pricing","estimate"] }
          }
        },
        {
          "name": "2. Tìm tài xế gần đây",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/drivers/nearby?lat=10.7769&lng=106.7009&radius=3&vehicleType=MOTORBIKE",
              "host": ["{{base_url}}"], "path": ["api","drivers","nearby"],
              "query": [
                { "key": "lat", "value": "10.7769" },
                { "key": "lng", "value": "106.7009" },
                { "key": "radius", "value": "3" },
                { "key": "vehicleType", "value": "MOTORBIKE" }
              ]
            }
          }
        },
        {
          "name": "3. Đặt xe (Cash)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.rideId || (res.data && res.data.id)) {",
                  "  const id = res.rideId || res.data.id;",
                  "  pm.collectionVariables.set('rideId', id);",
                  "  console.log('rideId saved:', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup\": {\n    \"lat\": 10.7769,\n    \"lng\": 106.7009,\n    \"address\": \"Quận 1, TP.HCM\"\n  },\n  \"dropoff\": {\n    \"lat\": 10.8231,\n    \"lng\": 106.6297,\n    \"address\": \"Tân Bình, TP.HCM\"\n  },\n  \"vehicleType\": \"MOTORBIKE\",\n  \"paymentMethod\": \"CASH\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/bookings", "host": ["{{base_url}}"], "path": ["api","bookings"] }
          }
        },
        {
          "name": "3b. Đặt xe (MoMo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup\": {\n    \"lat\": 10.7769,\n    \"lng\": 106.7009,\n    \"address\": \"Quận 1, TP.HCM\"\n  },\n  \"dropoff\": {\n    \"lat\": 10.8231,\n    \"lng\": 106.6297,\n    \"address\": \"Tân Bình, TP.HCM\"\n  },\n  \"vehicleType\": \"MOTORBIKE\",\n  \"paymentMethod\": \"MOMO\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/bookings", "host": ["{{base_url}}"], "path": ["api","bookings"] }
          }
        },
        {
          "name": "4. Xem trạng thái chuyến",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{base_url}}/api/rides/{{rideId}}", "host": ["{{base_url}}"], "path": ["api","rides","{{rideId}}"] }
          }
        },
        {
          "name": "5. Hủy chuyến",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Thay đổi kế hoạch\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/rides/{{rideId}}/cancel", "host": ["{{base_url}}"], "path": ["api","rides","{{rideId}}","cancel"] }
          }
        },
        {
          "name": "6. Lịch sử chuyến xe",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{base_url}}/api/rides/customer/history?page=1&limit=10", "host": ["{{base_url}}"], "path": ["api","rides","customer","history"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "7. Đánh giá tài xế",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"rating\": 5,\n  \"comment\": \"Tài xế rất tốt, lái xe an toàn!\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/reviews", "host": ["{{base_url}}"], "path": ["api","reviews"] }
          }
        }
      ]
    },

