{
  "info": {
    "name": "FoxGo API",
    "_postman_id": "foxgo-api-collection-v1",
    "description": "FoxGo Cab Booking System — API Collection\n\nDefault Base URL for Docker Compose: http://localhost:3000\nProduction/staging: đổi biến {{base_url}} sang domain API tương ứng.\n\nFlow:\n1. Đăng ký tài khoản → lấy OTP bằng GET /api/auth/dev/otp trong mock mode → xác nhận → đăng nhập\n2. Request lấy OTP tự lưu mã vào biến {{otp}}\n3. customerToken tự động được lưu sau khi login\n4. Các request tiếp theo dùng {{customerToken}} hoặc {{driverToken}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "customerToken", "value": "", "type": "string" },
    { "key": "driverToken", "value": "", "type": "string" },
    { "key": "otp", "value": "", "type": "string" },
    { "key": "customerPhone", "value": "0901234501", "type": "string" },
    { "key": "driverPhone", "value": "0901234502", "type": "string" },
    { "key": "rideId", "value": "", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔑 Auth — Customer",
      "item": [
        {
          "name": "1. Gửi OTP đăng ký",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register-phone/start", "host": ["{{base_url}}"], "path": ["api","auth","register-phone","start"] }
          }
        },
        {
          "name": "2. Lấy OTP (mock mode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.otp) {",
                  "  pm.collectionVariables.set('otp', res.otp);",
                  "  console.log('OTP saved:', res.otp);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/dev/otp?phone={{customerPhone}}&purpose=register",
              "host": ["{{base_url}}"], "path": ["api","auth","dev","otp"],
              "query": [
                { "key": "phone", "value": "{{customerPhone}}" },
                { "key": "purpose", "value": "register" }
              ]
            }
          }
        },
        {
          "name": "3. Xác nhận OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register-phone/verify", "host": ["{{base_url}}"], "path": ["api","auth","register-phone","verify"] }
          }
        },
        {
          "name": "4. Hoàn tất đăng ký",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\",\n  \"password\": \"Test@123456\",\n  \"role\": \"CUSTOMER\",\n  \"firstName\": \"Khách Hàng\",\n  \"lastName\": \"Test\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register-phone/complete", "host": ["{{base_url}}"], "path": ["api","auth","register-phone","complete"] }
          }
        },
        {
          "name": "5. Đăng nhập (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.data?.tokens?.accessToken || res?.accessToken;",
                  "if (token) {",
                  "  pm.collectionVariables.set('customerToken', token);",
                  "  console.log('✅ customerToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\",\n  \"password\": \"Test@123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "6. Thông tin tôi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "7. Quên mật khẩu — Gửi OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/forgot-password", "host": ["{{base_url}}"], "path": ["api","auth","forgot-password"] }
          }
        },
        {
          "name": "7b. Lấy OTP reset password (mock)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.otp) {",
                  "  pm.collectionVariables.set('otp', res.otp);",
                  "  console.log('OTP saved:', res.otp);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/dev/otp?phone={{customerPhone}}&purpose=reset",
              "host": ["{{base_url}}"], "path": ["api","auth","dev","otp"],
              "query": [
                { "key": "phone", "value": "{{customerPhone}}" },
                { "key": "purpose", "value": "reset" }
              ]
            }
          }
        },
        {
          "name": "8. Đặt lại mật khẩu",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerPhone}}\",\n  \"otp\": \"{{otp}}\",\n  \"newPassword\": \"NewPass@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/reset-password", "host": ["{{base_url}}"], "path": ["api","auth","reset-password"] }
          }
        },
        {
          "name": "9. Đăng xuất",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },

