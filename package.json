{
  "name": "cab-booking-system",
  "version": "1.0.0",
  "description": "Cab Booking System - Microservices Architecture",
  "private": true,
  "workspaces": [
    "services/*",
    "shared",
    "shared/*",
    "tests/*"
  ],
  "scripts": {
    "db:seed": "tsx scripts/seed-database.ts",
    "seed:flows": "npx tsx scripts/seed-flows.ts",
    "drivers:online": "node scripts/set-drivers-online.mjs",
    "db:migrate:driver-license-2026": "tsx scripts/migrate-driver-license-classes-2026.ts",
    "seed:vn-admin": "tsx scripts/import-vn-admin-data.ts",
    "dev:admin": "npm --prefix apps/admin-dashboard start",
    "dev:customer": "npm --prefix apps/customer-app start",
    "dev:driver-app": "npm --prefix apps/driver-app start",
    "dev:frontends": "concurrently --names admin,customer,driver --prefix-colors blue,green,magenta \"npm run dev:admin\" \"npm run dev:customer\" \"npm run dev:driver-app\"",
    "dev:auth": "npm -w services/auth-service run dev",
    "dev:ride": "npm -w services/ride-service run dev",
    "dev:driver": "npm -w services/driver-service run dev",
    "dev:payment": "npm -w services/payment-service run dev",
    "dev:booking": "npm -w services/booking-service run dev",
    "dev:pricing": "npm -w services/pricing-service run dev",
    "dev:user": "npm -w services/user-service run dev",
    "dev:notification": "npm -w services/notification-service run dev",
    "dev:review": "npm -w services/review-service run dev",
    "dev:gateway": "npm -w services/api-gateway run dev",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test --workspaces --if-present -- --runInBand --testPathIgnorePatterns=/__tests__/contracts/",
    "test:contract": "npm -w services/driver-service run test -- --runInBand src/__tests__/contracts/internal-driver-response.contract.test.ts && npm -w services/ride-service run test -- --runInBand src/__tests__/contracts/driver-service.contract.test.ts",
    "simulate:gps": "tsx scripts/simulate-driver-gps.ts",
    "test:integration": "tsx scripts/test-backend.ts",
    "test:backend": "tsx scripts/test-backend.ts",
    "smoke:gateway": "tsx scripts/smoke-gateway-flows.ts",
    "smoke:lifecycle": "tsx scripts/smoke-gateway-flows.ts",
    "smoke:browser": "npm --prefix apps/customer-app run cypress:run -- --spec \"cypress/e2e/ride-lifecycle.cy.ts,cypress/e2e/ride-cancellations.cy.ts\"",
    "smoke:browser:lifecycle": "npm --prefix apps/customer-app run cypress:run -- --spec cypress/e2e/ride-lifecycle.cy.ts",
    "smoke:browser:cancellations": "npm --prefix apps/customer-app run cypress:run -- --spec cypress/e2e/ride-cancellations.cy.ts",
    "test:ride": "npm -w services/ride-service run test",
    "test:auth": "npm -w services/auth-service run test",
    "test:shared": "npm -w shared run test",
    "test:coverage": "npm run test --workspaces --if-present -- --coverage",
    "build": "npm run build:shared && npm run build:backend",
    "build:shared": "npm -w shared run build",
    "build:backend": "npm -w services/api-gateway run build && npm -w services/auth-service run build && npm -w services/user-service run build && npm -w services/ride-service run build && npm -w services/driver-service run build && npm -w services/payment-service run build && npm -w services/wallet-service run build && npm -w services/notification-service run build && npm -w services/review-service run build && npm -w services/booking-service run build && npm -w services/pricing-service run build",
    "build:services": "npm -w services/auth-service run build && npm -w services/ride-service run build && npm -w services/driver-service run build && npm -w services/payment-service run build && npm -w services/wallet-service run build && npm -w services/booking-service run build && npm -w services/pricing-service run build && npm -w services/api-gateway run build",
    "lint": "eslint . --ext .ts,.tsx",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:tri-app": "playwright test tests/playwright/specs/tri-app-ride-flow.spec.ts --workers=1",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report playwright-report",
    "docs:bao-cao-bundle": "node scripts/publish-bao-cao-docs-bundle.mjs",
    "docs:verify-bao-cao-img": "node scripts/verify-bao-cao-img-refs.mjs"
  },
  "keywords": [
    "microservices",
    "cab-booking",
    "nodejs",
    "fastapi",
    "docker"
  ],
  "author": "KLTN2025",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "pg": "^8.18.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "twilio": "^5.13.0"
  }
}
