flowchart LR
    subgraph CustomerLane[Customer]
        C1[Dang ky / Dang nhap]
        C2[Nhap diem don, diem tra]
        C3[Nhan bao gia]
        C4[Tao va xac nhan booking]
        C5[Theo doi trang thai ride]
        C6[Thanh toan]
        C7[Danh gia tai xe]
    end

    subgraph DriverLane[Driver]
        D1[Dang ky driver]
        D2[Duoc verify]
        D3[Online va cap nhat vi tri]
        D4[Nhan offer / browse ride]
        D5[Accept hoac reject]
        D6[Pickup, start, complete]
        D7[Xem thu nhap]
    end

    subgraph AdminLane[Admin]
        A1[Quan ly user role]
        A2[Verify driver]
        A3[Xem dashboard]
        A4[Xem ride, payment, stats]
        A5[Refund neu can]
    end

    C1 --> C2 --> C3 --> C4 --> C5 --> C6 --> C7
    D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7
    A1 --> A2 --> A3 --> A4 --> A5

    C4 -. kich hoat .-> D4
    D5 -. trang thai realtime .-> C5
    D6 -. hoan tat ride .-> C6
    C6 -. du lieu doanh thu .-> D7
    A2 -. mo khoa kha nang nhan chuyen .-> D3
    A4 -. giam sat he thong .-> C5
