# ============================================
# CAB BOOKING SYSTEM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# Used by docker-compose.yml, docker-compose.prod.yml, and docker-stack.yml
# ============================================

# ============ Image Registry / Release ============
# Required for docker-compose.prod.yml and docker-stack.yml
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ============ Database Configuration ============
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cab_booking

MONGO_USER=mongo
MONGO_PASSWORD=mongo

# ============ Message Queue ============
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ============ Cache ============
REDIS_PASSWORD=redis123

# ============ Security ============
# IMPORTANT: Change these in production!
JWT_SECRET=test-jwt-secret
REFRESH_TOKEN_SECRET=test-refresh-secret
INTERNAL_SERVICE_TOKEN=test-internal-token

# JWT Token Expiry
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ============ Maps & Routing (OSM/OSRM) ============
OSRM_BASE_URL=http://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
AI_SERVICE_URL=http://ai-service:8000

# ============ Service URLs (Internal) ============
# These are internal Docker network URLs
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3007
BOOKING_SERVICE_URL=http://booking-service:3008
PRICING_SERVICE_URL=http://pricing-service:3009
REVIEW_SERVICE_URL=http://review-service:3010
RIDE_SERVICE_URL=http://ride-service:3002
DRIVER_SERVICE_URL=http://driver-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3005

# ============ External Service URLs ============
# For frontend applications (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============ Optional: Email Configuration ============
# Uncomment and configure if using email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@cabbooking.com

# ============ Optional: SMS Configuration ============
# Uncomment and configure if using SMS notifications
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============ Optional: Payment Gateway ============
# Keep blank if using mock payments only
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ============ Optional: AWS S3 (File Storage) ============
# Uncomment and configure if using S3 for file storage
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=cab-booking-uploads

# ============ Optional: Redis Configuration ============
# REDIS_DB=0

# ============ Monitoring / Admin ============
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ============ Application Configuration ============
NODE_ENV=development
LOG_LEVEL=debug

# ============ Rate Limiting ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ CORS Configuration ============
CORS_ORIGIN=http://localhost:3000

# ============ AI Service (docker-compose / Swarm) ============
# For chatbot quality matching local dev: set the same keys as services/ai-service/.env
# (OPENAI_API_KEY, GROQ_API_KEY, GEMINI_API_KEY, ANTHROPIC_API_KEY, AI_INTERNAL_TOKEN).
# Stack defaults use HF_HUB_OFFLINE=1 (no Hugging Face download). Local often uses 0 — add
# to ~/cab-booking/.env before deploy to fetch embeddings/rerankers (needs internet):
#   HF_HUB_OFFLINE=0
#   TRANSFORMERS_OFFLINE=0
# If you keep HF offline and the image has no reranker cache, disable reranker to avoid load errors:
# RAG_RERANKER_ENABLED=false
# AWS EC2 (VPC 172.31.0.0/16): put VPC DNS first so containers get IPv4 for huggingface.co / googleapis (dig works; getent may prefer IPv6 only).
# AI_SERVICE_DNS_1=172.31.0.2
# AI_SERVICE_DNS_2=8.8.8.8
# If ai-service still fails to resolve huggingface.co (gaierror -3), pin A record from: dig +short huggingface.co @172.31.0.2 | head -1
# HUGGINGFACE_EXTRA_HOST=13.35.202.34
# Or set Docker daemon "dns": ["172.31.0.2","8.8.8.8"] then restart docker (brief Swarm blip).

# ============================================
# PRODUCTION CHECKLIST:
# ============================================
# [ ] Change JWT_SECRET to a strong random string
# [ ] Change INTERNAL_SERVICE_TOKEN to a strong random string
# [ ] Update all default passwords (postgres, rabbitmq, etc.)
# [ ] Configure proper CORS_ORIGIN
# [ ] Set NODE_ENV=production
# [ ] Configure SSL/TLS certificates
# [ ] Set up proper logging and monitoring
# [ ] Configure backup strategy
# [ ] Set up proper rate limiting
# [ ] Configure external services (Email, SMS, Payment)
# ============================================
